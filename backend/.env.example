# MockVue Backend Configuration
# 1. Rename this file to .env
# 2. Update the values for your production environment (Render + TiDB)

# DATABASE
# ------------------------------------------------------------------------------
# TiDB Cloud Connection String (Standard URL format)
# mysql+pymysql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=mysql+pymysql://root:@127.0.0.1:3306/mockvue

# SECURITY
# ------------------------------------------------------------------------------
# Secret key for JWT signing (Auto-generated or a long random string)
SECRET_KEY=mockvue-super-secret-jwt-key-2025
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# AI Configuration (GROQ)
# ------------------------------------------------------------------------------
# Your Groq API Key
GROQ_API_KEY=gsk_your_key_here
